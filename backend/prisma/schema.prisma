generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  phoneNumber     String           @unique
  createdAt       DateTime         @default(now())
  name            String
  isFirstTime     Boolean          @default(true)
  budgets         Budget[]
  expenses        Expense[]
  sessions        Session[]
  vendorPayments  VendorPayment[]
  cashDeposits    CashDeposit[]
  dailySales      DailySales[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastMessage  String?
  currentState String?
  user         User     @relation(fields: [userId], references: [id])
}

model Expense {
  id             String   @id @default(uuid())
  userId         String
  amount         Float
  category       String
  date           DateTime @default(now())
  imageUrl       String?
  createdAt      DateTime @default(now())
  description    String?
  rawText        String?
  source         String
  structuredData Json?
  user           User     @relation(fields: [userId], references: [id])
}

model Budget {
  id             String   @id @default(uuid())
  userId         String
  category       String
  amount         Float
  period         String
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  alertThreshold Float    @default(0.8)
  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, category, period, startDate])
}

model VendorPayment {
  id            String    @id @default(uuid())
  userId        String
  vendorName    String
  amount        Float
  date          DateTime  @default(now())
  refBillNo     String?
  paymentMode   String?
  notes         String?
  status        String    @default("paid")
  rawText       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId, vendorName])
  @@index([userId, date])
}

model CashDeposit {
  id          String   @id @default(uuid())
  userId      String
  amount      Float
  date        DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

model DailySales {
  id              String   @id @default(uuid())
  userId          String
  date            DateTime
  totalExpenses   Float    @default(0)
  totalVendor     Float    @default(0)
  cashCollected   Float    @default(0)
  openingBalance  Float    @default(0)
  salesAmount     Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}
